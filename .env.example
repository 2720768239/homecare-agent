# HomeCare Agent v0.1 环境变量

# ===== 前端 (apps/web) =====
# 是否使用 Mock 模式（true = 前端独立运行，无需后端）
NEXT_PUBLIC_USE_MOCK=true

# 后端 API 地址（Mock 模式下忽略）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ===== 后端 (apps/api) =====
# Mock Auth（v0.1 始终 true）
MOCK_AUTH=true

# 数据库（v0.1 使用内存存储，以下为预留）
# DATABASE_URL=postgresql://homecare:homecare@localhost:5432/homecare

# S3/MinIO（v0.1 使用 mock URL，以下为预留）
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=homecare

# OpenAI（v0.1 节点工具 mock，以下为预留）
# OPENAI_API_KEY=sk-xxx
