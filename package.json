{
  "name": "homecare-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:web && npm run install:api",
    "install:web": "npm install --prefix apps/web",
    "install:api": "node scripts/install-api.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:api": "cd apps/api && .venv\\Scripts\\python.exe -m uvicorn main:app --reload --port 8000",
    "build": "npm run build --prefix apps/web",
    "lint": "npm run lint --prefix apps/web",
    "test:api": "cd apps/api && .venv\\Scripts\\python.exe -m pytest"
  }
}
